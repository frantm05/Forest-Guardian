{
  "expo": {
    "name": "PestDetector",
    "slug": "PestDetector",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.matej.forestguardian",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-camera",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikace potřebuje přístup k vašim fotkám pro analýzu škůdců."
        }
      ],
      "onnxruntime-react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "bc254fe2-f46c-4a45-b39c-05b946a0af50"
      }
    }
  }
}
